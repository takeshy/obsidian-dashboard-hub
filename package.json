    "esbuild": "^0.28.1",
    "obsidian": "^1.10.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "yaml": "^2.9.0"
  },
  "dependencies": {
    "fflate": "^0.8.3",
    "lucide-react": "^0.503.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
